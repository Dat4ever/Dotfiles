{
    "layer": "top",
    "position": "top",
    "height": 33,
    "margin-top": 16,
    "margin-left": 16,
    "margin-right": 16,
    "margin-bottom": 4,
    "modules-left": ["clock", "hyprland/workspaces"],
    "modules-center": [],
    "modules-right": ["tray", "idle_inhibitor", "custom/language", "pulseaudio", "backlight", "battery", "custom/power"],

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "hyprland/workspaces": {
        "sort-by-name": true,
        "on-click": "activate"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%d/%m/%Y %A}",
        "tooltip": false
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": { "activated": "", "deactivated": "" }
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": [""],
        "on-scroll-up": "brightnessctl set +1%",
        "on-scroll-down": "brightnessctl set 1%-"
    },

    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{icon} {volume}% {format_source}",
        "format-bluetooth-muted": " {format_source}",
        "format-muted": " {format_source}",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "headset": "🎧",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "custom/power": {
        "format": "",
        "on-click": "bash ~/.config/hypr/wofi-logout.sh"
    },

    "custom/language": {
        "exec": "hyprctl devices -j | jq -r '.keyboards[] | select(.main==true) | .active_keymap' | grep -qi turkish && echo   TR || echo   EN",
        "interval": 1,
        "tooltip": false
    }
}
